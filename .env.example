# Server
PORT=8083
NODE_ENV=development

# PostgreSQL — schema auth (users internos)
DATABASE_URL=postgresql://user:password@localhost:5435/garage_auth

# PostgreSQL — schema os_service (leitura de customer para login por CPF/CNPJ)
OS_DATABASE_URL=postgresql://user:password@localhost:5432/garage_os

# JWT RS256
# Gerar par de chaves: veja TASKS.md #7.3
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
# Colocar o conteúdo em uma linha com \n entre os breaks
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_EXPIRES_IN=8h

# Datadog
DD_TRACE_ENABLED=false
DD_SERVICE=garage-auth-service
DD_ENV=development
DD_VERSION=1.0.0
DD_AGENT_HOST=localhost
